+class DataProcessor:
+    def __init__(self, source, config):
+        self.source = source
+        self.config = config
+        self.cache = LRUCache(maxsize=config.cache_size)
+        self.timeout = config.timeout
+
+    def process(self, items):
+        validated = [i for i in items if self._validate(i)]
+        return [self._transform(i) for i in validated]
+
+    def _validate(self, item):
+        return item.valid and item.value > 0
+
+    def _transform(self, item):
+        return item.value * self.config.multiplier
+

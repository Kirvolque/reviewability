diff --git a/src/formatter.py b/src/formatter.py
--- a/src/formatter.py
+++ b/src/formatter.py
@@ -1,5 +1,7 @@
-def format_output(data):
-    lines = []
-    for k, v in data.items():
-        lines.append(f"{k}={v}")
-    return "\n".join(lines)
+def format_output(
+    data: dict,
+    separator: str = "\n",
+    key_value_sep: str = "=",
+    prefix: str = "",
+) -> str:
+    """Format a dict as a human-readable string."""
+    return separator.join(
+        f"{prefix}{k}{key_value_sep}{v}" for k, v in data.items()
+    )
